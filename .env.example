# ============================================================
# T212 CashGuard Trader — Environment Configuration
# Copy to .env. NEVER commit .env to version control.
# ============================================================

APP_MODE=mock
APP_NAME=T212 CashGuard Trader
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
MASTER_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

POSTGRES_USER=cashguard
POSTGRES_PASSWORD=cashguard_secret
POSTGRES_DB=cashguard
DATABASE_URL=postgresql+asyncpg://cashguard:cashguard_secret@localhost:5432/cashguard

REDIS_PASSWORD=cashguard_redis
REDIS_URL=redis://:cashguard_redis@localhost:6379/0

ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change-me-on-first-run

# Legacy generic keys are ignored by normal mock flows. Prefer the separated
# demo/live variables below and never put broker secrets in NEXT_PUBLIC_*.
T212_API_KEY=
T212_API_SECRET=
T212_ENVIRONMENT=demo
T212_DEMO_API_KEY=
T212_DEMO_API_SECRET=
T212_LIVE_API_KEY=
T212_LIVE_API_SECRET=

# ── Market data ──────────────────────────────────────────────────────────────
#
# LIVE SIGNALS — Alpaca (real-time, free paper account)
#   1. Go to https://alpaca.markets → create free account
#   2. Choose Paper Trading (no money needed)
#   3. Generate API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
#
# BACKTESTING — Polygon.io (15-min delayed, free tier)
#   1. Go to https://polygon.io → create free account
#   2. Copy API Key from Dashboard
POLYGON_API_KEY=
#
# OPTIONAL NEWS / CATALYST INTELLIGENCE — Benzinga
#   1. Provision a Benzinga API key
#   2. Add it here to enable structured catalyst/news scoring on the watchlist endpoint
BENZINGA_API_KEY=
# Use mock for local/CI mock-paper E2E. auto is available for dedicated
# non-mock market-data tests, but may call Alpaca/Polygon when keys are set.
MARKET_DATA_PROVIDER=auto
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BENZINGA_BASE_URL=https://api.benzinga.com

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_MODE=mock
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENABLE_PWA=false

CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CONFIRM_WINDOW_SECONDS=120
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
HTTP_PORT=80
HTTPS_PORT=443

# ── Sentry error tracking (optional — leave empty to disable) ─────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Data retention
AUDIT_LOG_RETENTION_DAYS=90
RISK_EVENT_RETENTION_DAYS=30

# Safety flags
CASH_ONLY_MODE=true
LIVE_TRADING_ENABLED=false

# Drawdown-adaptive sizing thresholds
DRAWDOWN_TIER1_PCT=0.5
DRAWDOWN_TIER2_PCT=1.0
DRAWDOWN_TIER3_PCT=1.5

# Strategy promotion pipeline thresholds
STRATEGY_PROMOTION_MIN_DRY_RUN_SIGNALS=3
STRATEGY_PROMOTION_MIN_DRY_RUN_DAYS=1
STRATEGY_PROMOTION_MIN_DEMO_ORDERS=3
STRATEGY_PROMOTION_MIN_DEMO_DAYS=2
STRATEGY_PROMOTION_MIN_DEMO_FILL_RATE=0.50
STRATEGY_PROMOTION_MAX_DEMO_ERROR_RATE=0.25
STRATEGY_PROMOTION_MAX_DEMO_RISK_BLOCK_RATE=0.50

# Portfolio-level allocator thresholds
PORTFOLIO_ALLOCATOR_MIN_SCORE=0.55
PORTFOLIO_ALLOCATOR_BASE_GROSS_EXPOSURE_PCT=75.0
PORTFOLIO_ALLOCATOR_VOLATILE_GROSS_EXPOSURE_PCT=45.0
PORTFOLIO_ALLOCATOR_RISK_OFF_GROSS_EXPOSURE_PCT=25.0
PORTFOLIO_ALLOCATOR_MAX_SYMBOL_EXPOSURE_PCT=20.0
PORTFOLIO_ALLOCATOR_MAX_SLEEVE_SYMBOL_EXPOSURE_PCT=60.0
PORTFOLIO_ALLOCATOR_MAX_RUN_RISK_PCT=2.0
