# ============================================================
# T212 CashGuard Trader - Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --------------------------
# Application mode
# Options: mock | demo | live
# Start with mock - no credentials required
# --------------------------
APP_MODE=mock

# --------------------------
# Security keys
# Generate with: openssl rand -hex 32
# --------------------------
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# --------------------------
# Database
# --------------------------
POSTGRES_USER=cashguard
POSTGRES_PASSWORD=cashguard_secret
POSTGRES_DB=cashguard
DATABASE_URL=postgresql+asyncpg://cashguard:cashguard_secret@localhost:5432/cashguard

# --------------------------
# Redis
# --------------------------
REDIS_PASSWORD=cashguard_redis
REDIS_URL=redis://:cashguard_redis@localhost:6379/0

# --------------------------
# Trading 212 API credentials
# Leave blank in mock mode. Set for demo/live.
# Get from: Trading 212 > Settings > API
# --------------------------
T212_API_KEY=
T212_API_SECRET=
# Options: demo | live
T212_ENVIRONMENT=demo

# --------------------------
# Frontend
# --------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_MODE=mock

# --------------------------
# Local app admin user (first run)
# --------------------------
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change-me-on-first-run

# --------------------------
# Alerts (optional)
# --------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --------------------------
# Logging
# --------------------------
LOG_LEVEL=INFO

# --------------------------
# CORS
# --------------------------
CORS_ORIGINS=http://localhost:3000
